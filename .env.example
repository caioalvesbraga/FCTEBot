# ──────────────────────────────────────────────────────────────────────────────
# FCTEBot — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────────────────────────────────────

# ── Aplicação ─────────────────────────────────────────────────────────────────
APP_NAME=FCTEBot
DEBUG=false
LOG_LEVEL=INFO

# ── Telegram ──────────────────────────────────────────────────────────────────
# Obtenha via @BotFather no Telegram
TELEGRAM_TOKEN=seu_token_aqui

# URL pública para webhook (deixe vazio para usar polling em dev)
TELEGRAM_WEBHOOK_URL=

# ── Ollama (LLM local) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
# Modelo padrão: qwen2.5:3b é recomendado por melhor suporte ao português
# Alternativas: gemma3:4b, llama3.2:3b, phi4-mini
OLLAMA_MODEL=qwen2.5:0.5b
# CPU/WSL: use 300s; 60s causa timeout frequente
OLLAMA_TIMEOUT=300

# ── Gemini (fallback ou primário) ─────────────────────────────────────────────
# IMPORTANTE: chaves AI Studio podem ser AIza... (legado) ou AQ.... (auth key, padrão 2026)
# Obtenha em: https://aistudio.google.com/app/apikey
# Se der 429, verifique billing em https://ai.studio/projects
# Projetos com créditos pré-pagos esgotados não usam free tier
# Para o TCC (local-first): LLM_STRATEGY=local_only dispensa Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Estratégia LLM: local_first | gemini_only | local_only
# - local_first: Ollama primeiro, Gemini se falhar ou confiança baixa (padrão)
# - gemini_only: pula Ollama (útil para testar Gemini ou CPU lenta)
# - local_only: nunca usa Gemini
LLM_STRATEGY=local_first

# ── Embeddings ────────────────────────────────────────────────────────────────
# intfloat/multilingual-e5-base: melhor suporte ao português para retrieval
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DEVICE=cpu

# ── Re-ranker ─────────────────────────────────────────────────────────────────
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANKER_TOP_K=2

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=6
RETRIEVAL_TFIDF_WEIGHT=0.4
RETRIEVAL_DENSE_WEIGHT=0.6
# 0.0 = aceita respostas locais curtas; 0.65 dispara fallback Gemini
CONFIDENCE_THRESHOLD=0.0

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_L1_TTL=604800     # 7 dias (respostas exatas)
CACHE_L2_TTL=2592000    # 30 dias (contextos similares)
CACHE_L2_SIMILARITY_THRESHOLD=0.95

# ── Base de Conhecimento ──────────────────────────────────────────────────────
# A base de conhecimento original do FCTEBot está em "Infos Adms UnB/"
# (caminho com espaço — use aspas no shell se necessário)
# Caminho dentro do container (mapeado pelo volume no docker-compose.yml)
KNOWLEDGE_BASE_PATH=Infos Adms UnB
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Geração LLM ───────────────────────────────────────────────────────────────
TEMPERATURE=0.2
MAX_TOKENS=300

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_USER=30

# ── Monitoramento ─────────────────────────────────────────────────────────────
METRICS_PORT=9090

# ── Setup na primeira subida ──────────────────────────────────────────────────
# SKIP_FIRST_RUN_SETUP=true   → pula atualização de docs (ex: ambiente sem internet)
# FORCE_SETUP=true            → força re-download mesmo que já tenha sido inicializado
SKIP_FIRST_RUN_SETUP=false
FORCE_SETUP=false
